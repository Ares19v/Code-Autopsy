# ══════════════════════════════════════════════════════════════════════════════
# Code Autopsy — .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
*.egg-info/
dist/
build/
.eggs/

# ── Environment ───────────────────────────────────────────────────────────────
.env
*.env.local

# ── Data (large raw/processed files never committed) ──────────────────────────
data/raw/
data/processed/
*.jsonl
*.parquet
*.arrow

# ── Model weights & checkpoints ───────────────────────────────────────────────
checkpoints/
adapter/
merged_model/
*.gguf
*.ggml
*.safetensors
*.pt
*.pth
*.bin

# ── Experiment tracking ───────────────────────────────────────────────────────
wandb/
mlruns/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── HuggingFace cache ─────────────────────────────────────────────────────────
.cache/

# ── Debug / scratch scripts ───────────────────────────────────────────────────
debug_hang.py
scratch/
