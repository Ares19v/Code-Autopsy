# ── HuggingFace ───────────────────────────────────────────────────────────────
# Write token — needed to push models to Ares19v/code-autopsy-7b and Ares19v/code-autopsy-lora
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Weights & Biases ──────────────────────────────────────────────────────────
# Get from: https://wandb.ai/authorize
WANDB_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WANDB_PROJECT=code-autopsy
WANDB_ENTITY=                  # leave blank to use your default W&B entity

# ── Gemini API (LLM-as-judge evaluation) ──────────────────────────────────────
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GitHub (optional — not needed if using HF dataset snapshots) ───────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── FastAPI serving ───────────────────────────────────────────────────────────
# URL the Gradio demo calls for inference; change when deploying
API_URL=http://localhost:8000
